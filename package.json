{
  "scripts": {
    "build": "rollup -c",
    "prototype": "node src/prototype/print-snapshot.js",
    "prototype:once": "node src/prototype/print-snapshot.js --once",
    "prototype:json": "node src/prototype/print-snapshot.js --once --json",
    "test": "node --test test/*.test.js",
    "dev": "npm-run-all plugin:unlink plugin:link -p plugin:watch plugin:debug",
    "plugin:watch": "rollup -c -w --watch.onEnd=\"npm run plugin:restart\"",
    "plugin:unlink": "flexcli plugin unlink --uuid com.aspen.flexbar-ai-dashboard --silent",
    "plugin:link": "flexcli plugin link --path com.aspen.flexbar-ai-dashboard.plugin --uuid com.aspen.flexbar-ai-dashboard --start false",
    "plugin:restart": "flexcli plugin restart --uuid=com.aspen.flexbar-ai-dashboard",
    "plugin:debug": "flexcli plugin debug --uuid=com.aspen.flexbar-ai-dashboard",
    "plugin:validate": "flexcli plugin validate --path com.aspen.flexbar-ai-dashboard.plugin",
    "plugin:pack": "flexcli plugin pack --path com.aspen.flexbar-ai-dashboard.plugin",
    "plugin:install": "flexcli plugin install --path ./com.aspen.flexbar-ai-dashboard.flexplugin --force"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "commonjs",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.2.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "@rollup/plugin-json": "^6.1.0",
    "npm-run-all": "^4.1.5",
    "rollup": "^4.0.2"
  },
  "dependencies": {
    "@eniac/flexdesigner": "^1.0.7",
    "@napi-rs/canvas": "^0.1.80"
  },
  "version": "1.0.0"
}
